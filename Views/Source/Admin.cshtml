@using linc.Utility
@using Microsoft.AspNetCore.Localization
@model SourceIndexViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "bg";
}

@section Breadcrumbs {
    <!-- ======= Breadcrumbs ======= -->
    <section class="breadcrumbs">
        <div class="container">

            <div class="d-flex justify-content-between align-items-center">
                <h2>@ViewData["Title"]</h2>
                <ol>
                    <li>
                        <a href="/">@HtmlLocalizer["NavItem_Home"]</a>
                    </li>
                    <li>
                        <a asp-area="Identity" asp-page="/Account/Manage/Administration">@HtmlLocalizer["ManageNavItem_Administration"]</a>
                    </li>
                    <li>
                        @HtmlLocalizer["List_Label"]
                    </li>
                </ol>
            </div>

        </div>
    </section>
    <!-- End Breadcrumbs -->
}

<h1>Index</h1>

<small>Language: @currentCulture</small>

@if (Model.CurrentIssueNumber.HasValue && Model.CurrentReleaseYear.HasValue)
{
    <div class="alert alert-info">
        <strong>@HtmlLocalizer["Issue_Label"]:</strong> @IIssueService.DisplayIssueLabelInformation(Model.CurrentIssueNumber.Value, Model.CurrentReleaseYear.Value)
    </div>
}

<ul class="list-operations">
    <li>
        <a asp-area="Identity" asp-page="/Account/Manage/Administration">Administration</a>
    </li>
    <li>
        <a asp-action="Create">Create New</a>
    </li>
</ul>

<hr />

<div class="table-responsive">
    <table class="table">
        <thead class="table-light">
        <tr>
            <th>
                Author
            </th>
            <th>
                Title
            </th>
            <th class="text-center">
                Pages
            </th>
            <th class="text-center">
                Issue
            </th>
            <th class="text-center">
                DOI
            </th>
            <th>
                Created
            </th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Records)
        {
            var rowClass = string.Empty;
            if (item.IsTheme)
            {
                rowClass = "table-primary";
            }
            else if (item.IsSection)
            {
                rowClass = "table-light";
            }

            <tr class="@rowClass">
                <td>
                    @* TODO: Link to user admin screen if exist *@
                    @Html.DisplayFor(modelItem => item.AuthorNames) <br/>
                    @Html.Raw(item.AuthorNotes?.ReplaceLineEndings("<br>"))
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">
                        @Html.DisplayFor(modelItem => item.Title) 
                    </a>
                    <br/>
                    @Html.DisplayFor(modelItem => item.TitleNotes)
                </td>
                <td class="text-center">
                    <a href="@Url.Action("LoadIssueDocument", "Document", new { issueId = item.IssueId })#page=@item.StartingPdfPage" target="_blank">
                        @item.StartingIndexPage
                    </a>
                    <br />
                    <a href="@Url.Action("LoadSourceDocument", "Document", new { sourceId = item.Id })" target="_blank">
                        @Html.DisplayFor(modelItem => item.StartingPdfPage)-@Html.DisplayFor(modelItem => item.LastPdfPage)
                    </a>
                </td>
                <td class="text-center">
                    <a asp-action="Details" asp-controller="Issue" asp-route-id="@item.IssueId">
                        @IIssueService.DisplayIssueLabelInformation(item.Issue.IssueNumber, item.Issue.ReleaseYear)
                    </a>
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.HasDOI)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DateCreated)
                </td>
            </tr>
        }
        </tbody>
    </table>
    
    @if (Model.TotalPages > 1)
    {
        @* Custom issue-based pagination *@
        <div class="paging text-center">
            @if (Model.HasPreviousPage && Model.PreviousIssueNumber.HasValue && Model.PreviousIssueYear.HasValue)
            {
                <a class="newer" href="@Url.Action("Admin", new { page = Model.PageIndex - 1 })">
                    <i class="bi bi-arrow-left"></i> @HtmlLocalizer["PreviousPage_Label"] (@IIssueService.DisplayIssueLabelInformation(Model.PreviousIssueNumber.Value, Model.PreviousIssueYear.Value))
                </a>
            }
            else
            {
                <a class="newer disabled" href="#">
                    <i class="bi bi-arrow-left"></i> @HtmlLocalizer["PreviousPage_Label"]
                </a>
            }

            <span>•</span>
            
            @if (Model.CurrentIssueNumber.HasValue && Model.CurrentReleaseYear.HasValue)
            {
                <span class="active">@IIssueService.DisplayIssueLabelInformation(Model.CurrentIssueNumber.Value, Model.CurrentReleaseYear.Value)</span>
            }
            else
            {
                <span class="active">@Model.PageIndex</span>
            }
            
            <span>•</span>

            @if (Model.HasNextPage && Model.NextIssueNumber.HasValue && Model.NextIssueYear.HasValue)
            {
                <a class="older" href="@Url.Action("Admin", new { page = Model.PageIndex + 1 })">
                    @HtmlLocalizer["NextPage_Label"] (@IIssueService.DisplayIssueLabelInformation(Model.NextIssueNumber.Value, Model.NextIssueYear.Value)) <i class="bi bi-arrow-right"></i>
                </a>
            }
            else
            {
                <a class="older disabled" href="#">
                    @HtmlLocalizer["NextPage_Label"] <i class="bi bi-arrow-right"></i>
                </a>
            }
        </div>
    }
</div>